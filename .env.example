# ============================================================
# FanGuide AI — Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- Google Gemini ---
# Your Google Gemini API key. Get one at https://aistudio.google.com/apikey
# This key is ONLY used server-side and is NEVER sent to the browser.
GEMINI_API_KEY=your_gemini_api_key_here

# --- Server ---
PORT=3001
NODE_ENV=development

# --- CORS ---
# The origin of your frontend dev server (Vite default: 5173)
# In production, set this to your deployed frontend URL.
FRONTEND_ORIGIN=http://localhost:5173

# --- Rate Limiting ---
# Max requests per window per IP on the /api/chat endpoint
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=20

# --- Crowd Density Simulation ---
# How often (ms) the server randomizes crowd density values
CROWD_REFRESH_INTERVAL_MS=30000
